  "name": "coralnpu-rvv-core",
  "version": "0.1.0",
  "description": "RISC-V Vector (RVV 1.0) execution engine implementing Zve32x integer vector extension with optional Zve32f floating-point support. Configurable VLEN (128/256/512/1024-bit, set via compile-time `define), multi-lane dispatch (4 lanes default), out-of-order execution with reorder buffer. 2 ALU, 2 MUL, 1 DIV, 1 permutation/reduction, 2 LSU, and optional 2 FMA units. From Google CoralNPU project. NOTE: RvvCore is a vector CO-PROCESSOR with no bus port; it attaches directly to a host scalar RISC-V core via custom datapath handshakes (instruction issue, scalar/FP register-file read/write, async writeback, LSU micro-op, vector CSR, and retire), NOT via TL-UL/AXI/APB.",
  "license": "Apache-2.0",
  "maturity": "rtl_verified",
  "target": ["asic", "fpga"],
  "design_type": ["digital"],
  "created": "2026-03-27T20:52:56Z",
  "updated": "2026-03-27T20:52:56Z",
  "source": {
    "type": "git",
    "url": "https://github.com/google-coral/coralnpu",
    "commit": "main",
    "ip_path": "hdl/verilog/rvv",
