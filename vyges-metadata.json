    "indexing": true
  },
  "maintainers": [{"name": "Vyges", "email": "team@vyges.com", "url": "https://vyges.com", "github": "vyges"}],
  "interfaces": [
    {"type": "clock", "direction": "input", "protocol": "generic", "port": "clk", "width": 1, "description": "System clock."},
    {"type": "reset", "direction": "input", "protocol": "generic", "port": "rstn", "polarity": "active_low", "width": 1, "description": "Active-low reset."},
    {"type": "custom", "direction": "input", "protocol": "custom", "port": "inst_valid/inst_data/inst_ready", "description": "Instruction issue handshake from host scalar core: N-wide inst_valid + RVVInstruction inst_data in, inst_ready out (NOT a bus)."},
    {"type": "custom", "direction": "both", "protocol": "custom", "port": "reg_read_valid/reg_read_data/reg_write_valid/reg_write_addr/reg_write_data", "description": "Scalar register file datapath: 2*N read ports (valid+data in), N write ports (valid+addr+data out)."},
    {"type": "custom", "direction": "both", "protocol": "custom", "port": "freg_read_data/async_frd_valid/async_frd_addr/async_frd_data/async_frd_ready", "description": "Floating-point scalar register datapath (optional Zve32f): N freg read data in, async FP writeback handshake."},
    {"type": "custom", "direction": "both", "protocol": "custom", "port": "async_rd_valid/async_rd_addr/async_rd_data/async_rd_ready", "description": "Asynchronous scalar register writeback handshake (valid/addr/data out, ready in)."},
    {"type": "custom", "direction": "both", "protocol": "custom", "port": "uop_lsu_*_rvv2lsu/uop_lsu_*_lsu2rvv", "description": "Load/store unit micro-op handshake (NUM_LSU lanes): rvv2lsu request (index/VRF/v0-mask) and lsu2rvv response, with ready/valid both directions. Not a memory bus."},
    {"type": "custom", "direction": "both", "protocol": "custom", "port": "vstart/vxrm/vxsat/frm/vcsr_valid/vector_csr/vcsr_ready/config_state_valid/config_state", "description": "Vector CSR datapath: vstart/vxrm/vxsat/frm inputs; vector_csr and config_state outputs with valid/ready handshake."},
    {"type": "custom", "direction": "output", "protocol": "custom", "port": "rd_rob2rt_o/rd_valid_rob2rt_o/rvv_idle/queue_capacity/trap_valid_o/trap_data_o/wr_vxsat_valid_o/wr_vxsat_o", "description": "Retire/status outputs: NUM_RT_UOP ROB-to-retire write ports, rvv_idle, queue_capacity, trap signaling, and vxsat writeback."}
  ],
  "parameters": [
    {"name": "N", "type": "int", "default": 4, "description": "Number of instruction lanes (host scalar core issue width)."},
    {"name": "CMD_BUFFER_MAX_CAPACITY", "type": "int", "default": 16, "description": "Command buffer maximum capacity."}
  ],
